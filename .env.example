# OpenAI API key (Whisper 음성인식 + GPT 제목추론/독음/해석)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Genius API access token (정식 가사 크롤링)
# https://genius.com/api-clients 에서 client 생성 후 "Client Access Token" 복사
GENIUS_ACCESS_TOKEN=...

# 사용할 모델 (필요시 변경)
OPENAI_IDENTIFY_MODEL=gpt-4o
OPENAI_ANNOTATE_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# 노래방 강제정렬용 로컬 모델 크기 (tiny/base/small/medium/large)
# 클수록 정확하지만 느리고 다운로드 큼. small 권장(첫 실행 시 ~461MB 다운로드)
STABLE_TS_MODEL=small

# --- 관리자 계정 (서버 부팅 시 자동 생성, approved+admin) ---
# 반드시 본인 것으로 변경하세요. 이 계정으로 로그인하면 승인 관리가 가능합니다.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# 세션 쿠키 서명 키(비우면 data/secret.key 에 자동 생성)
SESSION_SECRET=
